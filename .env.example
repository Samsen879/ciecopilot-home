# ==================== Runtime ====================
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== Supabase / DB ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Legacy compatibility aliases (kept for existing scripts/routes)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==================== Auth ====================
JWT_SECRET=replace_with_strong_random_secret
AUTH_ENFORCE_SESSIONS=false

# ==================== Marking switches ====================
MARKING_V1_ENABLED=true

# ==================== Evidence Ledger ====================
# Structured evidence tables (attempts, mark_runs, mark_decisions, error_events)
EVIDENCE_LEDGER_ENABLED=true

# ==================== LLM / Embedding ====================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4o-mini

DASHSCOPE_API_KEY=your_dashscope_api_key

EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# Optional vector embedding aliases used by some scripts
VECTOR_EMBEDDING_API_KEY=your_embedding_api_key
VECTOR_EMBEDDING_BASE_URL=https://api.openai.com/v1/embeddings
VECTOR_EMBEDDING_MODEL=text-embedding-3-large
VECTOR_EMBEDDING_DIMENSIONS=3072

# ==================== Frontend ====================
VITE_API_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000
VITE_RAG_API_BASE=/api/rag
VITE_RAG_API_TIMEOUT=30000
VITE_DEFAULT_SUBJECT_CODE=9709
VITE_USE_MSW=false
